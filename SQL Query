Creating table named retail_sales
CREATE TABLE retail_sales (
    transaction_id     INT PRIMARY KEY,
    date               DATE,
    customer_id        VARCHAR(20),
    gender             VARCHAR(10),
    age                INT,
    product_category   VARCHAR(50),
    quantity           INT,
    price_per_unit     DECIMAL(10,2),
    total_amount       DECIMAL(10,2)
);

SQL queries:-
1)To view all records
SELECT * FROM retail_sales;

2)Total number of transactions
SELECT COUNT(*) AS total_transactions FROM retail_sales;

3)View the specific columns
SELECT transaction_id, customer_id, product_category, total_amount
FROM retail_sales;

4)Unique product categories
SELECT DISTINCT product_category FROM retail_sales;

5)Filter — only Electronics
SELECT * FROM retail_sales
WHERE product_category = 'Electronics';

6)Sort by total amount (highest first)
SELECT * FROM retail_sales
ORDER BY total_amount DESC;

7)Top 10 highest transactions
SELECT * FROM retail_sales
ORDER BY total_amount DESC
LIMIT 10;

8)Total revenue
SELECT SUM(total_amount) AS total_revenue FROM retail_sales;

9)Total revenue by each category
SELECT product_category,
       SUM(total_amount) AS revenue,
       COUNT(*) AS num_transactions
FROM retail_sales
GROUP BY product_category
ORDER BY revenue DESC;

10)Avg spent by gender
SELECT gender,
       ROUND(AVG(total_amount), 2) AS avg_spend
FROM retail_sales
GROUP BY gender;

11)Total quantity sold per each category
SELECT product_category,
       SUM(quantity) AS total_units_sold
FROM retail_sales
GROUP BY product_category;

12)Categories with revenue above ₹50,000 (HAVING)
SELECT product_category,
       SUM(total_amount) AS revenue
FROM retail_sales
GROUP BY product_category
HAVING SUM(total_amount) > 50000;

13)Customer id in uppercase
SELECT UPPER(customer_id) AS customer_id_upper,
       total_amount
FROM retail_sales;

14)Age groups and their spending
SELECT 
    CASE 
        WHEN age BETWEEN 18 AND 25 THEN '18-25'
        WHEN age BETWEEN 26 AND 35 THEN '26-35'
        WHEN age BETWEEN 36 AND 50 THEN '36-50'
        ELSE '51+' 
    END AS age_group,
    COUNT(*) AS transactions,
    ROUND(AVG(total_amount), 2) AS avg_spend,
    SUM(total_amount) AS total_revenue
FROM retail_sales
GROUP BY age_group
ORDER BY total_revenue DESC;

15)Rank customers by total spend (Window Function)
SELECT 
    customer_id,
    SUM(total_amount) AS total_spent,
    RANK() OVER (ORDER BY SUM(total_amount) DESC) AS spend_rank
FROM retail_sales
GROUP BY customer_id;

16)Each customer's most purchased category (Subquery)
SELECT customer_id, product_category, times_purchased
FROM (
    SELECT customer_id, product_category,
           COUNT(*) AS times_purchased,
           RANK() OVER (PARTITION BY customer_id ORDER BY COUNT(*) DESC) AS rnk
    FROM retail_sales
    GROUP BY customer_id, product_category
) ranked
WHERE rnk = 1;

17)Revenue contribution % by a category
SELECT 
    product_category,
    SUM(total_amount) AS revenue,
    ROUND(SUM(total_amount) * 100.0 / SUM(SUM(total_amount)) OVER (), 2) AS pct_contribution
FROM retail_sales
GROUP BY product_category;

18)Top 5 customers with highest spending
SELECT customer_id,
       SUM(total_amount) AS total_spent
FROM retail_sales
GROUP BY customer_id
ORDER BY total_spent DESC
LIMIT 5;

19)Revenue and avg transaction value by category
SELECT product_category,
       COUNT(*) AS transactions,
       SUM(total_amount) AS total_revenue,
       ROUND(AVG(total_amount), 2) AS avg_transaction_value,
       SUM(quantity) AS units_sold
FROM retail_sales
GROUP BY product_category
ORDER BY total_revenue DESC;

20)Gender vs category and buys
SELECT gender, product_category,
       SUM(total_amount) AS revenue,
       COUNT(*) AS transactions
FROM retail_sales
GROUP BY gender, product_category
ORDER BY gender, revenue DESC;

21)Top category per age group
SELECT age_group, product_category, revenue
FROM (
    SELECT 
        CASE 
            WHEN age BETWEEN 18 AND 25 THEN '18-25'
            WHEN age BETWEEN 26 AND 35 THEN '26-35'
            WHEN age BETWEEN 36 AND 50 THEN '36-50'
            ELSE '51-64'
        END AS age_group,
        product_category,
        SUM(total_amount) AS revenue,
        RANK() OVER (
            PARTITION BY 
                CASE 
                    WHEN age BETWEEN 18 AND 25 THEN '18-25'
                    WHEN age BETWEEN 26 AND 35 THEN '26-35'
                    WHEN age BETWEEN 36 AND 50 THEN '36-50'
                    ELSE '51-64'
                END
            ORDER BY SUM(total_amount) DESC
        ) AS rnk
    FROM retail_sales
    GROUP BY age_group, product_category
) ranked
WHERE rnk = 1;

22)Avg quantity sold per category
SELECT product_category,
       ROUND(AVG(quantity), 2) AS avg_qty,
       SUM(quantity) AS total_units
FROM retail_sales
GROUP BY product_category
ORDER BY avg_qty DESC;

23)Bulk buyers — transactions with quantity ≥ 4
SELECT product_category,
       COUNT(*) AS bulk_transactions,
       SUM(total_amount) AS bulk_revenue
FROM retail_sales
WHERE quantity >= 4
GROUP BY product_category
ORDER BY bulk_transactions DESC;

24)Quantity vs revenue correlation check
SELECT quantity,
       COUNT(*) AS transactions,
       ROUND(AVG(total_amount), 2) AS avg_revenue,
       SUM(total_amount) AS total_revenue
FROM retail_sales
GROUP BY quantity
ORDER BY quantity;

25)Transactions split by quantity bucket
SELECT 
    CASE 
        WHEN quantity = 1 THEN 'Single item'
        WHEN quantity = 2 THEN 'Small buy'
        WHEN quantity = 3 THEN 'Medium buy'
        ELSE 'Bulk buy'
    END AS purchase_type,
    COUNT(*) AS transactions,
    ROUND(AVG(total_amount), 2) AS avg_spend
FROM retail_sales
GROUP BY purchase_type
ORDER BY transactions DESC;

26)Transactions below average spend (underperformers)
SELECT product_category,
       COUNT(*) AS below_avg_txns
FROM retail_sales
WHERE total_amount < (SELECT AVG(total_amount) FROM retail_sales)
GROUP BY product_category
ORDER BY below_avg_txns DESC;

27)Busiest day of each month
SELECT month, date, daily_revenue
FROM (
    SELECT 
        DATE_FORMAT(date, '%Y-%m') AS month,
        date,
        SUM(total_amount) AS daily_revenue,
        RANK() OVER (
            PARTITION BY DATE_FORMAT(date, '%Y-%m')
            ORDER BY SUM(total_amount) DESC
        ) AS rnk
    FROM retail_sales
    GROUP BY month, date
) ranked
WHERE rnk = 1
ORDER BY month;

28) Which price point generates most revenue
SELECT price_per_unit,
       COUNT(*) AS times_sold,
       SUM(quantity) AS total_units,
       SUM(total_amount) AS total_revenue
FROM retail_sales
GROUP BY price_per_unit
ORDER BY total_revenue DESC;

29)Percentile rank of each transaction
SELECT transaction_id, total_amount,
       ROUND(PERCENT_RANK() OVER (ORDER BY total_amount) * 100, 1) AS percentile_rank
FROM retail_sales
ORDER BY total_amount DESC
LIMIT 20;

30)Running total of transactions per category
SELECT date, product_category, total_amount,
       SUM(total_amount) OVER (
           PARTITION BY product_category
           ORDER BY date
       ) AS running_total
FROM retail_sales
ORDER BY product_category, date;


